# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (server-only, never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=

# App URL for auth redirects (http://localhost:3000 for dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public URL of the app surface (app.quotacanary.com). Sign-in / CTA links on the marketing site point here.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AES-256 key for encrypting tool API keys at rest (server-only). Generate: openssl rand -base64 32
ENCRYPTION_KEY=

# Shared secret guarding the /api/poll balance-refresh endpoint (server-only)
POLL_SECRET=

# Postmark server API token for transactional + alert emails (server-only).
# Optional: without it the app still runs and just skips email alerts (in-app
# alerts keep working). See docs/SELF_HOSTING.md.
POSTMARK_SERVER_TOKEN=

# Marketing origin used for app→docs links. Prod is set on Railway;
# locally you can point at http://marketing.localhost:3000 if you run the
# marketing surface, otherwise the default sends you to the live docs.
NEXT_PUBLIC_MARKETING_URL=https://quotacanary.com

# Self-host single-domain mode. Set to "true" when you run QuotaCanary on one
# domain (no marketing/app host split) so every request serves the app. Leave
# unset for the two-surface hosted setup.
APP_ONLY=
